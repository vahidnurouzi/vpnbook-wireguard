name: Update VPNBook Config

on:
  schedule:
    - cron: '0 */2 * * *'  # هر ۲ ساعت یکبار اجرا می‌شود
  workflow_dispatch:       # امکان اجرای دستی

jobs:
  update-config:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Download VPNBook WireGuard config
        run: |
          wget -O vpnbook-wg.conf https://www.vpnbook.com/wireguard/DE1.conf || \
          wget -O vpnbook-wg.conf https://www.vpnbook.com/wireguard/NL1.conf || \
          wget -O vpnbook-wg.conf https://www.vpnbook.com/wireguard/FR1.conf

      - name: Commit and push if config changed
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add vpnbook-wg.conf
          git diff --staged --quiet || git commit -m "Update VPNBook config"
          git push
